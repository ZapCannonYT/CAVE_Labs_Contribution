# Health AI Local Environment Configuration
# Set this to true to allow chat.html to connect without API key or Firebase token authentication locally
HEALTH_AI_ALLOW_UNAUTHENTICATED=true

# GPU offload layers: 0 = CPU-only (default), -1 = full GPU offload (requires CUDA toolkit and llama-cpp-python compiled with CUDA)
HEALTH_AI_GPU_LAYERS=0
